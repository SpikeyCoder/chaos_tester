# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment / secrets
.env
.env.*

# Reports (contain target-specific data — regenerate per run)
reports/*.json

# Screenshots
screenshots/

# OS files
.DS_Store
Thumbs.db
# PSI key fix

# Editor backup files (do not commit)
*.bak
*.bak[0-9]
*.bak[0-9][0-9]
*.orig
*.swp

# Claude Code worktrees (transient working state, never commit)
.claude/worktrees/

# Node — root-level package.json declares no dependencies; node_modules
# should never be committed here. The /frontend project has its own
# node_modules entry in /frontend/.gitignore (or its own scope).
node_modules/
package-lock.json
